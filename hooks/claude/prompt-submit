#!/usr/bin/env bash
# Claude Code hook: prompt-submit — fired when user submits a prompt

set -euo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
PROJECT_ROOT="$(dirname "$(dirname "$SCRIPT_DIR")")"
LIB_DIR="$PROJECT_ROOT/lib"

source "$LIB_DIR/state.sh"

state_init

# Determine session name from tmux
session_name="$(tmux display-message -p '#{session_name}' 2>/dev/null || echo "")"

if [[ -z "$session_name" ]]; then
    exit 0
fi

# Only act on tracked sessions
if ! state_session_exists "$session_name"; then
    exit 0
fi

# Set state to working
state_write_session "$session_name" "state" "working"

# Clear idle_since
state_write_session "$session_name" "idle_since" ""

# Export state dir for summary writing
export AGENT_STATE_DIR="$SESSIONS_DIR/$session_name"

# Refresh waybar
"$PROJECT_ROOT/bin/agent-mode-toggle" refresh

# Regenerate workspace colors
if [[ -x "$PROJECT_ROOT/integration/waybar-workspace-colors.sh" ]]; then
    "$PROJECT_ROOT/integration/waybar-workspace-colors.sh" 2>/dev/null || true
fi
