#!/usr/bin/env bash
# agent-session-queue — Priority queue view of sessions (UUID-keyed)

set -euo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"

source "$LIB_DIR/state.sh"

state_init

_format_duration() {
    local seconds="$1"
    local hours=$(( seconds / 3600 ))
    local mins=$(( (seconds % 3600) / 60 ))
    printf "%02d:%02d" "$hours" "$mins"
}

_read_summary() {
    local uuid="$1"
    local summary_file="$SESSIONS_DIR/$uuid/summary"

    if [[ -f "$summary_file" ]]; then
        local priority summary
        priority="$(grep '^PRIORITY:' "$summary_file" 2>/dev/null | awk '{print $2}' || echo "3")"
        summary="$(grep '^SUMMARY:' "$summary_file" 2>/dev/null | cut -d: -f2- | xargs || echo "")"
        echo "${priority:-3}|${summary:-no summary}"
    else
        echo "3|no summary"
    fi
}

now="$(date +%s)"

# Build entries with sort keys
entries=()
for uuid in $(state_list_sessions); do
    name="$(state_get_name "$uuid")"
    [[ -n "$name" ]] || continue

    state="$(state_read_session "$uuid" "state" 2>/dev/null || echo "idle")"
    agent="$(state_read_session "$uuid" "agent" 2>/dev/null || echo "?")"
    idle_since="$(state_read_session "$uuid" "idle_since" 2>/dev/null || echo "$now")"
    cwd="$(state_get_cwd "$name")"
    cwd="${cwd/#$HOME/\~}"

    summary_data="$(_read_summary "$uuid")"
    priority="${summary_data%%|*}"
    summary="${summary_data#*|}"

    # Duration
    if [[ "$state" == "working" ]]; then
        duration="working"
        idle_elapsed=0
    else
        idle_elapsed=$(( now - idle_since ))
        duration="$(_format_duration "$idle_elapsed")"
    fi

    # Sort key: state (working=0, idle=1), priority (inverted), idle_elapsed
    state_sort=$( [[ "$state" == "working" ]] && echo "0" || echo "1" )
    priority_sort=$(( 10 - priority ))

    # Color
    if [[ "$state" == "working" ]]; then
        color_code="33"
    elif (( idle_elapsed > 600 )); then
        color_code="31"
    else
        color_code="32"
    fi

    printf -v entry "%s|%s|%06d|\033[%sm P%s  %-20s %-8s %-8s %-8s %-40s %s\033[0m|%s" \
        "$state_sort" "$priority_sort" "$idle_elapsed" \
        "$color_code" "$priority" "$name" "$agent" "$state" "$duration" "$summary" "$cwd" \
        "$uuid"
    entries+=("$entry")
done

if [[ ${#entries[@]} -eq 0 ]]; then
    echo "No active sessions" >&2
    exit 0
fi

# Sort and display (uuid is hidden in last field after second |)
selection="$(printf '%s\n' "${entries[@]}" | sort -t'|' -k1,1 -k2,2 -k3,3n | \
    while IFS='|' read -r s1 s2 s3 display uuid_field; do
        printf '%s|%s\n' "$display" "$uuid_field"
    done | fzf \
    --ansi \
    --no-sort \
    --header="Priority Queue — select to jump" \
    --prompt="queue> " \
    --delimiter='|' \
    --with-nth=1 \
)"

if [[ -n "$selection" ]]; then
    # Extract UUID from hidden field
    selected_uuid="$(echo "$selection" | awk -F'|' '{print $NF}')"
    state_set_active "$selected_uuid"

    workspace="$(state_read_session "$selected_uuid" "workspace" 2>/dev/null || echo "")"
    if [[ -n "$workspace" ]]; then
        hyprctl dispatch workspace "$workspace" 2>/dev/null || true
    fi

    "$SCRIPT_DIR/agent-mode-toggle" refresh
fi
