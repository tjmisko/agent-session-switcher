#!/usr/bin/env bash
# agent-session-picker-rofi — Rofi-based session picker (UUID-keyed)

set -euo pipefail

source "$(dirname "$(readlink -f "$0")")/../lib/log.sh"
log_init
if [[ -n "${DEBUG:-}" ]]; then
    exec 2>>"$LOG_DIR/debug-agent-session-picker-rofi.log"
    set -x
fi

# Ensure full user PATH (needed when launched from WM keybind without shell profile)
[[ -f "$HOME/.profile" ]] && source "$HOME/.profile" 2>/dev/null || true
[[ -f "$HOME/.bash_profile" ]] && source "$HOME/.bash_profile" 2>/dev/null || true

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"

source "$LIB_DIR/state.sh"

state_init

_format_duration() {
    local seconds="$1"
    local hours=$(( seconds / 3600 ))
    local mins=$(( (seconds % 3600) / 60 ))
    local secs=$(( seconds % 60 ))
    printf "%02d:%02d:%02d" "$hours" "$mins" "$secs"
}

_build_session_list_rofi() {
    local now active
    now="$(date +%s)"
    active="$(state_get_active)"

    # --- Live sessions ---
    for uuid in $(state_list_sessions); do
        local name state idle_since cwd duration_str indicator color

        name="$(state_get_name "$uuid")"
        [[ -n "$name" ]] || continue

        state="$(state_read_session "$uuid" "state" 2>/dev/null || echo "idle")"
        idle_since="$(state_read_session "$uuid" "idle_since" 2>/dev/null || echo "")"
        cwd="$(state_get_cwd "$name")"
        cwd="${cwd/#$HOME/\~}"

        # Duration + color
        if [[ "$state" == "working" ]]; then
            duration_str="working"
            color="#e5c07b"  # yellow
        elif [[ -n "$idle_since" ]]; then
            local elapsed=$(( now - idle_since ))
            duration_str="$(_format_duration "$elapsed")"
            if (( elapsed > 600 )); then
                color="#e06c75"  # red
            else
                color="#98c379"  # green
            fi
        else
            duration_str="idle"
            color="#98c379"  # green
        fi

        # Active indicator
        if [[ "$uuid" == "$active" ]]; then
            indicator="▸"
        else
            indicator=" "
        fi

        # Embed UUID as invisible zero-width data at end (rofi strips ANSI)
        printf '%s <span color="%s">%-20s %-8s %-8s</span> %s <span size="0">%s</span>\n' \
            "$indicator" "$color" "$name" "$state" "$duration_str" "$cwd" "$uuid"
    done
}

_strip_pango() {
    sed 's/<[^>]*>//g'
}

_extract_uuid() {
    # UUID is the last whitespace-separated token after stripping pango
    _strip_pango | awk '{print $NF}'
}

while true; do
    set +e
    selection="$(_build_session_list_rofi | rofi -dmenu \
        -markup-rows \
        -p "agent" \
        -mesg "enter:attach  ctrl+n:new  ctrl+x:kill" \
        -kb-row-down "Down" \
        -kb-custom-1 "Control+n" \
        -kb-custom-2 "Control+x" \
        -kb-accept-entry "Return")"
    rc=$?
    set -e

    case "$rc" in
        0)
            # Enter — switch to session in wrapper terminal
            uuid="$(echo "$selection" | _extract_uuid)"
            if [[ -n "$uuid" ]]; then
                session_name="$(state_get_name "$uuid")"
                if [[ -n "$session_name" ]]; then
                    agent_tty="$(cat "$STATE_DIR/agent-tty" 2>/dev/null || echo "")"
                    if [[ -n "$agent_tty" ]]; then
                        tmux switch-client -c "$agent_tty" -t "$session_name"
                    else
                        # No wrapper running — spawn one
                        wezterm start --class agentTerminal -- "$SCRIPT_DIR/agent-session-terminal" &
                        disown
                    fi
                fi
            fi
            exit 0
            ;;
        10)
            # ctrl+n — create new session and switch to it
            tmux start-server 2>/dev/null || true
            new_session="$("$SCRIPT_DIR/agent-session-create")" || true
            if [[ -n "$new_session" ]]; then
                agent_tty="$(cat "$STATE_DIR/agent-tty" 2>/dev/null || echo "")"
                if [[ -n "$agent_tty" ]]; then
                    tmux switch-client -c "$agent_tty" -t "$new_session"
                else
                    wezterm start --class agentTerminal -- "$SCRIPT_DIR/agent-session-terminal" &
                    disown
                fi
                exit 0
            fi
            continue
            ;;
        11)
            # ctrl+x — kill live or dismiss dead, re-open picker
            uuid="$(echo "$selection" | _extract_uuid)"
            if [[ -n "$uuid" ]]; then
                session_name="$(state_get_name "$uuid")"
                if [[ -n "$session_name" ]]; then
                    tmux kill-session -t "$session_name" 2>/dev/null || true
                fi
            fi
            # If no sessions remain, exit
            if [[ -z "$(state_list_sessions)" ]]; then
                exit 0
            fi
            continue
            ;;
        *)
            # Escape / cancel
            exit 0
            ;;
    esac
done
