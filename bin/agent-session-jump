#!/usr/bin/env bash
# agent-session-jump — Jump to the active session's workspace

set -euo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"

source "$LIB_DIR/state.sh"

state_init

active="$(state_get_active)"

if [[ -z "$active" ]]; then
    echo "No active session" >&2
    exit 1
fi

workspace="$(state_read_session "$active" "workspace" 2>/dev/null || echo "")"

if [[ -z "$workspace" ]]; then
    echo "No workspace set for session '$active'" >&2
    exit 1
fi

hyprctl dispatch workspace "$workspace" 2>/dev/null || true
