#!/usr/bin/env bash
# agent-session-restore — Restore sessions from manifest on boot

set -euo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"

source "$LIB_DIR/config.sh"
source "$LIB_DIR/state.sh"
source "$LIB_DIR/manifest.sh"

state_init
manifest_init

restored=0

for session_name in $(manifest_list); do
    # Skip if tmux session already exists
    if tmux has-session -t "$session_name" 2>/dev/null; then
        continue
    fi

    agent="$(manifest_get "$session_name" "agent")"
    uuid="$(manifest_get "$session_name" "uuid")"
    cwd="$(manifest_get "$session_name" "cwd")"
    workspace="$(manifest_get "$session_name" "workspace")"

    if [[ -z "$agent" || -z "$uuid" ]]; then
        continue
    fi

    # Read agent config
    command="$(config_get_agent "$agent" "command")"
    resume_flag="$(config_get_agent "$agent" "resume_flag")"

    if [[ -z "$command" ]]; then
        echo "Unknown agent '$agent' for session '$session_name', skipping" >&2
        continue
    fi

    # Build command
    cmd_args=("$command")
    if [[ -n "$resume_flag" ]]; then
        cmd_args+=($resume_flag "$uuid")
    fi

    # Create tmux session
    tmux new-session -d -s "$session_name" -c "${cwd:-$HOME}" "${cmd_args[@]}"

    # Set tmux environment
    tmux set-environment -t "$session_name" AGENT_STATE_DIR "$SESSIONS_DIR/$session_name"
    tmux set-environment -t "$session_name" CLAUDE_CWD "${cwd:-$HOME}"

    # Create state file
    state_write_session "$session_name" "state" "idle"
    state_write_session "$session_name" "agent" "$agent"
    state_write_session "$session_name" "idle_since" "$(date +%s)"
    if [[ -n "$workspace" ]]; then
        state_write_session "$session_name" "workspace" "$workspace"
    fi

    (( restored++ ))
    echo "Restored: $session_name ($agent)"
done

echo "Restored $restored session(s)"
