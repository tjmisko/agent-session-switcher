#!/usr/bin/env bash
# agent-session-overlay — Opens session fullscreen in overlay terminal

set -euo pipefail

exec 2>/tmp/agent-session-overlay.log
set -x

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"

source "$LIB_DIR/config.sh"
source "$LIB_DIR/state.sh"

state_init

# Accept either a session name (for direct use) or resolve from active UUID
session_name="${1:-}"

if [[ -z "$session_name" ]]; then
    # Try active UUID
    active_uuid="$(state_get_active)"
    if [[ -n "$active_uuid" ]]; then
        session_name="$(state_get_name "$active_uuid")"
    fi
fi

if [[ -z "$session_name" ]]; then
    echo "No session specified and no active session" >&2
    exit 1
fi

if ! tmux has-session -t "$session_name" 2>/dev/null; then
    echo "Session '$session_name' does not exist" >&2
    exit 1
fi

# Look up UUID for state operations
uuid="$(state_find_uuid "$session_name")"

# Update active session (by UUID if available, fall back to name lookup)
if [[ -n "$uuid" ]]; then
    state_set_active "$uuid"

    # Get workspace and store it
    workspace="$(state_read_session "$uuid" "workspace" 2>/dev/null || echo "")"
    if [[ -z "$workspace" ]]; then
        workspace="$(hyprctl activeworkspace -j 2>/dev/null | jq -r '.id' 2>/dev/null || echo "1")"
        state_write_session "$uuid" "workspace" "$workspace"
    fi
fi

# Ensure waybar state
"$SCRIPT_DIR/agent-mode-toggle" ensure

# Spawn overlay terminal — hyprland window rules handle fullscreen
terminal="$(config_get_default "defaults.terminal" "wezterm")"

case "$terminal" in
    wezterm)
        wezterm start --class agent-session-overlay -- tmux attach-session -t "$session_name"
        ;;
    alacritty)
        alacritty --class agent-session-overlay -e tmux attach-session -t "$session_name"
        ;;
    kitty)
        kitty --class agent-session-overlay tmux attach-session -t "$session_name"
        ;;
    *)
        echo "Unsupported terminal: $terminal" >&2
        exit 1
        ;;
esac
