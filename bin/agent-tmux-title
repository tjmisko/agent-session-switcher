#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
source "$(dirname "$SCRIPT_DIR")/lib/state.sh"
state_init

uuid="${1:-}"
[[ -z "$uuid" ]] && { echo ""; exit 0; }

state="$(state_read_session "$uuid" "state" 2>/dev/null || echo "idle")"

case "$state" in
    working)    echo "working" ;;
    permission) echo "PERMISSION" ;;
    idle)
        idle_since="$(state_read_session "$uuid" "idle_since" 2>/dev/null || echo "")"
        if [[ -n "$idle_since" ]]; then
            now="$(date +%s)"
            elapsed=$(( now - idle_since ))
            printf "idle %02d:%02d:%02d\n" $(( elapsed/3600 )) $(( (elapsed%3600)/60 )) $(( elapsed%60 ))
        else
            echo "idle"
        fi
        ;;
    *)          echo "$state" ;;
esac
