#!/usr/bin/env bash
# agent-mode-toggle — Spawns/kills bottom waybar HUD bar

set -euo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"
WAYBAR_DIR="$(dirname "$SCRIPT_DIR")/waybar"

source "$LIB_DIR/state.sh"

state_init

action="${1:-toggle}"

_start_waybar() {
    local pid
    pid="$(state_get_waybar_pid)"

    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
        return 0
    fi

    waybar -c "$WAYBAR_DIR/config.jsonc" -s "$WAYBAR_DIR/style.css" &
    local new_pid=$!
    state_set_waybar_pid "$new_pid"
    state_set_mode "ai"
}

_stop_waybar() {
    local pid
    pid="$(state_get_waybar_pid)"

    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
        kill "$pid" 2>/dev/null || true
    fi

    rm -f "$STATE_DIR/waybar-pid"
    rm -f "$STATE_DIR/mode"
}

_refresh_waybar() {
    local pid
    pid="$(state_get_waybar_pid)"

    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
        pkill -RTMIN+10 waybar 2>/dev/null || true
    fi
}

case "$action" in
    enter)
        _start_waybar
        ;;
    exit)
        _stop_waybar
        ;;
    toggle)
        if [[ "$(state_get_mode)" == "ai" ]]; then
            _stop_waybar
        else
            _start_waybar
        fi
        ;;
    refresh)
        _refresh_waybar
        ;;
    *)
        echo "Usage: agent-mode-toggle {enter|exit|toggle|refresh}" >&2
        exit 1
        ;;
esac
