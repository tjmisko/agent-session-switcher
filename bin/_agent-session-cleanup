#!/usr/bin/env bash
# _agent-session-cleanup — Internal: mark session dead after tmux exit
# Called by tmux session-closed hook. Must be idempotent.
# Does NOT delete the state dir — preserves it for resume.

set -euo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"

source "$LIB_DIR/state.sh"

uuid="${1:-}"

if [[ -z "$uuid" ]]; then
    exit 0
fi

# Mark as dead (preserves dir for resume)
state_write_session "$uuid" "state" "dead"
state_write_session "$uuid" "dead_since" "$(date +%s)"

# Save CWD before session disappears (for resume)
# Note: session may already be gone by the time this runs,
# so we only write if we can read it
session_name="$(state_get_name "$uuid")"
if [[ -n "$session_name" ]]; then
    cwd="$(state_get_cwd "$session_name" 2>/dev/null || echo "")"
    if [[ -n "$cwd" ]]; then
        state_write_session "$uuid" "cwd" "$cwd"
    fi
fi

# If this was the active session, clear it
active="$(state_get_active)"
if [[ "$active" == "$uuid" ]]; then
    # Set active to first remaining live session, if any
    first="$(state_list_sessions | head -1)"
    if [[ -n "$first" ]]; then
        state_set_active "$first"
    else
        rm -f "$STATE_DIR/active-session"
    fi
fi

# Check remaining live sessions (exclude the one being cleaned up)
remaining="$(state_list_sessions | grep -cv "^${uuid}$" || true)"
if [[ "$remaining" -gt 0 ]]; then
    "$SCRIPT_DIR/agent-mode-toggle" refresh 2>/dev/null || true
else
    "$SCRIPT_DIR/agent-mode-toggle" exit 2>/dev/null || true
fi
