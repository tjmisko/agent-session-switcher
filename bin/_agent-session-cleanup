#!/usr/bin/env bash
# _agent-session-cleanup — Internal: remove session state after tmux exit
# Called by tmux session-closed hook. Must be idempotent.

set -euo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"

source "$LIB_DIR/log.sh"
source "$LIB_DIR/state.sh"

log_init

uuid="${1:-}"

if [[ -z "$uuid" ]]; then
    exit 0
fi

log_msg INFO "cleanup" "Session closed: $uuid"

# Delete the state dir entirely
state_remove_session "$uuid"

# If this was the active session, promote another
active="$(state_get_active)"
if [[ "$active" == "$uuid" ]]; then
    # Filter our own UUID when finding next session (avoid race)
    first="$(state_list_sessions | grep -v "^${uuid}$" | head -1 || true)"
    if [[ -n "$first" ]]; then
        state_set_active "$first"
    else
        rm -f "$STATE_DIR/active-session"
    fi
fi

# Refresh waybar
"$SCRIPT_DIR/agent-mode-toggle" refresh 2>/dev/null || true

# If no live sessions remain, exit AI mode
remaining="$(state_list_sessions | grep -cv "^${uuid}$" || true)"
if [[ "$remaining" -eq 0 ]]; then
    "$SCRIPT_DIR/agent-mode-toggle" exit 2>/dev/null || true
fi
