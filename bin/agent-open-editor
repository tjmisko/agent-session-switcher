#!/usr/bin/env bash
# agent-open-editor — Opens editor in active session's CWD, unfullscreens overlay

set -euo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"

source "$LIB_DIR/config.sh"
source "$LIB_DIR/state.sh"

state_init

active_uuid="$(state_get_active)"

if [[ -z "$active_uuid" ]]; then
    echo "No active session" >&2
    exit 1
fi

# Resolve tmux session name from UUID
session_name="$(state_get_name "$active_uuid")"

if [[ -z "$session_name" ]]; then
    echo "Active session no longer exists" >&2
    exit 1
fi

# Get CWD from tmux
cwd="$(state_get_cwd "$session_name")"

editor="$(config_get_default "defaults.editor" "nvim")"
terminal="$(config_get_default "defaults.terminal" "wezterm")"

# Unfullscreen the agent terminal
hyprctl dispatch fullscreen 0,class:agentTerminal 2>/dev/null || true

# Open editor in a new terminal window
case "$terminal" in
    wezterm)
        wezterm start --cwd "$cwd" -- "$editor" "$cwd"
        ;;
    alacritty)
        alacritty --working-directory "$cwd" -e "$editor" "$cwd"
        ;;
    kitty)
        kitty -d "$cwd" "$editor" "$cwd"
        ;;
esac
