#!/usr/bin/env bash
# agent-session-cycle — Cycle through sessions and jump to workspace

set -euo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"

source "$LIB_DIR/state.sh"

state_init

direction="${1:-up}"

# Get sorted session list
mapfile -t sessions < <(state_list_sessions | sort)

if [[ ${#sessions[@]} -eq 0 ]]; then
    exit 0
fi

active="$(state_get_active)"

# Find current index
current_idx=-1
for i in "${!sessions[@]}"; do
    if [[ "${sessions[$i]}" == "$active" ]]; then
        current_idx=$i
        break
    fi
done

# Calculate next index
count=${#sessions[@]}
if [[ "$direction" == "up" || "$direction" == "next" ]]; then
    next_idx=$(( (current_idx + 1) % count ))
elif [[ "$direction" == "down" || "$direction" == "prev" ]]; then
    next_idx=$(( (current_idx - 1 + count) % count ))
else
    echo "Usage: agent-session-cycle {up|down}" >&2
    exit 1
fi

next_session="${sessions[$next_idx]}"
state_set_active "$next_session"

# Jump to workspace
workspace="$(state_read_session "$next_session" "workspace" 2>/dev/null || echo "")"
if [[ -n "$workspace" ]]; then
    hyprctl dispatch workspace "$workspace" 2>/dev/null || true
fi

# Refresh waybar
"$SCRIPT_DIR/agent-mode-toggle" refresh
