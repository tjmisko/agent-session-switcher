#!/usr/bin/env bash
# agent-session-picker — FZF session picker (UUID-keyed, with dead session support)

set -euo pipefail

exec 2>/tmp/agent-session-picker.log
set -x

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"

source "$LIB_DIR/state.sh"

state_init

_format_duration() {
    local seconds="$1"
    local hours=$(( seconds / 3600 ))
    local mins=$(( (seconds % 3600) / 60 ))
    local secs=$(( seconds % 60 ))
    printf "%02d:%02d:%02d" "$hours" "$mins" "$secs"
}

_build_session_list() {
    local now active
    now="$(date +%s)"
    active="$(state_get_active)"

    # --- Live sessions ---
    for uuid in $(state_list_sessions); do
        local name state idle_since cwd duration_str indicator color_code

        name="$(state_get_name "$uuid")"
        [[ -n "$name" ]] || continue

        state="$(state_read_session "$uuid" "state" 2>/dev/null || echo "idle")"
        idle_since="$(state_read_session "$uuid" "idle_since" 2>/dev/null || echo "")"
        cwd="$(state_get_cwd "$name")"
        cwd="${cwd/#$HOME/\~}"

        # Duration
        if [[ "$state" == "working" ]]; then
            duration_str="working"
            color_code="33"  # yellow/orange
        elif [[ -n "$idle_since" ]]; then
            local elapsed=$(( now - idle_since ))
            duration_str="$(_format_duration "$elapsed")"
            if (( elapsed > 600 )); then
                color_code="31"  # red
            else
                color_code="32"  # green
            fi
        else
            duration_str="idle"
            color_code="32"  # green
        fi

        # Active indicator
        if [[ "$uuid" == "$active" ]]; then
            indicator="▸"
        else
            indicator=" "
        fi

        # Format: indicator name state duration cwd [uuid hidden at end]
        printf "%s \033[%sm%-20s %-8s %-8s\033[0m %s \033[90m%s\033[0m\n" \
            "$indicator" "$color_code" "$name" "$state" "$duration_str" "$cwd" "$uuid"
    done

    # --- Dead / resumable sessions ---
    for uuid in $(state_list_dead_sessions); do
        local agent summary_text dead_since cwd

        agent="$(state_read_session "$uuid" "agent" 2>/dev/null || echo "?")"
        dead_since="$(state_read_session "$uuid" "dead_since" 2>/dev/null || echo "")"
        cwd="$(state_read_session "$uuid" "cwd" 2>/dev/null || echo "")"
        cwd="${cwd/#$HOME/\~}"

        # Read summary if available
        summary_text=""
        if [[ -f "$SESSIONS_DIR/$uuid/summary" ]]; then
            summary_text="$(grep '^SUMMARY:' "$SESSIONS_DIR/$uuid/summary" 2>/dev/null | cut -d: -f2- | xargs || echo "")"
        fi

        local duration_str=""
        if [[ -n "$dead_since" ]]; then
            local elapsed=$(( now - dead_since ))
            duration_str="dead $(_format_duration "$elapsed")"
        else
            duration_str="dead"
        fi

        local display="${agent}(dead)"
        [[ -z "$summary_text" ]] || display="${display}: ${summary_text}"

        printf "  \033[90m%-20s %-8s %-8s %s\033[0m \033[90m%s\033[0m\n" \
            "$display" "$agent" "$duration_str" "$cwd" "$uuid"
    done
}

_extract_uuid() {
    # Strip ANSI escape codes, then grab last field (UUID)
    sed 's/\x1b\[[0-9;]*m//g' | awk '{print $NF}'
}

_pick_session() {
    local selection
    selection="$(_build_session_list | fzf \
        --ansi \
        --no-sort \
        --prompt="agent> " \
        --header="enter:attach/resume  ctrl-n:new  ctrl-x:kill/dismiss  ctrl-r:rename" \
        --bind="ctrl-n:execute($SCRIPT_DIR/agent-session-create)+reload($SCRIPT_DIR/agent-session-picker --list)" \
        --bind="ctrl-x:execute-silent($SCRIPT_DIR/_agent-session-picker-action kill {-1})+reload($SCRIPT_DIR/agent-session-picker --list)" \
        --bind="ctrl-r:execute-silent($SCRIPT_DIR/_agent-session-rename {2} {q})+reload($SCRIPT_DIR/agent-session-picker --list)" \
        --preview="$SCRIPT_DIR/_agent-session-picker-preview {-1}" \
        --preview-window=up:60% \
    )"

    if [[ -n "$selection" ]]; then
        echo "$selection" | _extract_uuid
    fi
}

# Handle --list flag for fzf reload
if [[ "${1:-}" == "--list" ]]; then
    _build_session_list
    exit 0
fi

selected_uuid="$(_pick_session)"

if [[ -n "$selected_uuid" ]]; then
    # Check if this is a dead session (resume) or live (attach)
    local_state="$(state_read_session "$selected_uuid" "state" 2>/dev/null || echo "")"

    if [[ "$local_state" == "dead" ]]; then
        # Resume: create new session from dead one
        new_name="$("$SCRIPT_DIR/agent-session-create" --resume "$selected_uuid")"
        if [[ -n "$new_name" ]]; then
            selected_uuid="$(state_find_uuid "$new_name")"
            session_name="$new_name"
        fi
    else
        session_name="$(state_get_name "$selected_uuid")"
    fi

    if [[ -n "${session_name:-}" ]]; then
        # State updates (inlined from agent-session-overlay)
        state_set_active "$selected_uuid"
        workspace="$(hyprctl activeworkspace -j 2>/dev/null | jq -r '.id' 2>/dev/null || echo "1")"
        state_write_session "$selected_uuid" "workspace" "$workspace"
        "$SCRIPT_DIR/agent-mode-toggle" ensure

        # Remove hypr-float-center state so Super+A spawns a fresh picker next time
        rm -f /tmp/hypr-float-center/agentPicker.conf

        exec tmux attach-session -t "$session_name"
    fi
fi
