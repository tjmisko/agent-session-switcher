#!/usr/bin/env bash
# agent-session-create — Create a new agent session (UUID-keyed)

set -euo pipefail

source "$(dirname "$(readlink -f "$0")")/../lib/log.sh"
log_init
if [[ -n "${DEBUG:-}" ]]; then
    exec 2>>"$LOG_DIR/debug-agent-session-create.log"
    set -x
fi

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"

source "$LIB_DIR/config.sh"
source "$LIB_DIR/state.sh"

state_init

# Parse args
agent=""
cwd=""
name=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --open)
            # Legacy flag, ignored (overlay removed)
            shift
            ;;
        *)
            # Positional args: agent, cwd, name
            if [[ -z "$agent" ]]; then
                agent="$1"
            elif [[ -z "$cwd" ]]; then
                cwd="$1"
            else
                name="$1"
            fi
            shift
            ;;
    esac
done

agent="${agent:-$(config_get_default "defaults.agent" "claude")}"
cwd="${cwd:-$(pwd)}"

command="$(config_get_agent "$agent" "command")"
prefix="$(config_get_agent "$agent" "session_prefix")"
session_id_flag="$(config_get_agent "$agent" "session_id_flag")"
system_prompt_flag="$(config_get_agent "$agent" "system_prompt_flag")"
has_hooks="$(config_get_agent "$agent" "hooks")"

# Generate session name if not provided
if [[ -z "$name" ]]; then
    n=1
    while tmux has-session -t "${prefix}${n}" 2>/dev/null; do
        (( ++n ))
    done
    name="${prefix}${n}"
fi

# Generate UUID
uuid="$(uuidgen 2>/dev/null || cat /proc/sys/kernel/random/uuid)"

# Build agent state dir and write pending state
agent_state_dir="$SESSIONS_DIR/$uuid"
mkdir -p "$agent_state_dir"
state_write_session "$uuid" "state" "pending"
state_write_session "$uuid" "agent" "$agent"
state_write_session "$uuid" "created_at" "$(date +%s)"

log_msg INFO "agent-session-create" "Creating session: name=$name uuid=$uuid agent=$agent"

# Build system prompt file
if [[ -n "$system_prompt_flag" ]]; then
    prompt_additions="$(config_get "system_prompt_additions")"
    priority_rules="$(config_get "priority_rules")"

    if [[ -n "$prompt_additions" || -n "$priority_rules" ]]; then
        full_prompt="AGENT_STATE_DIR=${agent_state_dir}
${prompt_additions}
${priority_rules}"
        printf '%s' "$full_prompt" > "$agent_state_dir/system-prompt"
    fi
fi

# Build the command string for send-keys
run_cmd="$command"
if [[ -n "$session_id_flag" ]]; then
    run_cmd+=" $session_id_flag $uuid"
fi
if [[ -n "$system_prompt_flag" && -f "$agent_state_dir/system-prompt" ]]; then
    run_cmd+=" $system_prompt_flag \"\$(cat '$agent_state_dir/system-prompt')\""
fi

# Unset CLAUDECODE to avoid recursion, then exec the agent command
run_cmd="unset CLAUDECODE; exec $run_cmd"

log_msg INFO "agent-session-create" "Run command: $run_cmd"

# Ensure tmux server is running
tmux start-server 2>/dev/null || true

# Create tmux session (interactive shell, no command) with hook and options
# set atomically. Using \; ensures all commands run in a single server
# round-trip, preventing a race where the session dies before hooks are
# registered.
tmux new-session -d -s "$name" -c "$cwd" \; \
    set-hook -t "$name" session-closed \
        "run-shell '$SCRIPT_DIR/_agent-session-cleanup $uuid'" \; \
    set-option -t "$name" @agent_uuid "$uuid" \; \
    set-environment -t "$name" AGENT_STATE_DIR "$agent_state_dir" \; \
    set-environment -t "$name" -u CLAUDECODE

# Send the command into the interactive shell
tmux send-keys -t "$name" "$run_cmd" Enter

# Verify session was created
if ! tmux has-session -t "$name" 2>/dev/null; then
    log_msg ERROR "agent-session-create" "tmux session failed to create: $name"
    state_remove_session "$uuid"
    exit 1
fi

# Transition from pending to idle
state_write_session "$uuid" "state" "idle"
state_write_session "$uuid" "idle_since" "$(date +%s)"

# Set as active
state_set_active "$uuid"

log_msg INFO "agent-session-create" "Session created: name=$name uuid=$uuid"

echo "$name"
