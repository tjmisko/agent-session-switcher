#!/usr/bin/env bash
# agent-session-create — Create a new agent session (UUID-keyed)

set -euo pipefail

source "$(dirname "$(readlink -f "$0")")/../lib/log.sh"
log_init
if [[ -n "${DEBUG:-}" ]]; then
    exec 2>>"$LOG_DIR/debug-agent-session-create.log"
    set -x
fi

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"

source "$LIB_DIR/config.sh"
source "$LIB_DIR/state.sh"

state_init

# Parse args
agent=""
cwd=""
name=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        *)
            # Positional args: agent, cwd, name
            if [[ -z "$agent" ]]; then
                agent="$1"
            elif [[ -z "$cwd" ]]; then
                cwd="$1"
            else
                name="$1"
            fi
            shift
            ;;
    esac
done

agent="${agent:-$(config_get_default "defaults.agent" "claude")}"
cwd="${cwd:-$(pwd)}"

# Read agent config
command="$(config_get_agent "$agent" "command")"
prefix="$(config_get_agent "$agent" "session_prefix")"
session_id_flag="$(config_get_agent "$agent" "session_id_flag")"
system_prompt_flag="$(config_get_agent "$agent" "system_prompt_flag")"
has_hooks="$(config_get_agent "$agent" "hooks")"

# Generate session name if not provided
if [[ -z "$name" ]]; then
    n=1
    while tmux has-session -t "${prefix}${n}" 2>/dev/null; do
        (( ++n ))
    done
    name="${prefix}${n}"
fi

# Generate UUID
uuid="$(uuidgen 2>/dev/null || cat /proc/sys/kernel/random/uuid)"

# Build agent state dir
agent_state_dir="$SESSIONS_DIR/$uuid"
mkdir -p "$agent_state_dir"

# Build command args
cmd_args=("$command")

if [[ -n "$session_id_flag" ]]; then
    cmd_args+=($session_id_flag "$uuid")
fi

# Build system prompt additions
if [[ -n "$system_prompt_flag" ]]; then
    prompt_additions="$(config_get "system_prompt_additions")"
    priority_rules="$(config_get "priority_rules")"

    if [[ -n "$prompt_additions" || -n "$priority_rules" ]]; then
        full_prompt="AGENT_STATE_DIR=${agent_state_dir}
${prompt_additions}
${priority_rules}"
        cmd_args+=($system_prompt_flag "$full_prompt")
    fi
fi

# Write launcher script to avoid tmux shell-command quoting issues
# (tmux joins args with spaces and passes to sh -c, breaking multiline values)
launcher="$agent_state_dir/launch.sh"
printf '#!/usr/bin/env bash\nunset CLAUDECODE\nexec %s\n' "${cmd_args[*]@Q}" > "$launcher"
chmod +x "$launcher"

# Create tmux session with hook and options set atomically.
# Using \; ensures all commands run in a single server round-trip,
# preventing a race where the session dies before hooks are registered.
tmux new-session -d -s "$name" -c "$cwd" "$launcher" \; \
    set-hook -t "$name" session-closed \
        "run-shell '$SCRIPT_DIR/_agent-session-cleanup $uuid'" \; \
    set-option -t "$name" @agent_uuid "$uuid" \; \
    set-environment -t "$name" AGENT_STATE_DIR "$agent_state_dir" \; \
    set-environment -t "$name" -u CLAUDECODE

# Write state file
state_write_session "$uuid" "state" "idle"
state_write_session "$uuid" "agent" "$agent"
state_write_session "$uuid" "idle_since" "$(date +%s)"

# Set as active
state_set_active "$uuid"

echo "$name"
