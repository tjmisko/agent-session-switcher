#!/usr/bin/env bash
# _agent-session-rename — Rename an agent session (just tmux, UUID is stable)

set -euo pipefail

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
LIB_DIR="$(dirname "$SCRIPT_DIR")/lib"

source "$LIB_DIR/state.sh"

old="${1:-}"
new="${2:-}"

if [[ -z "$old" || -z "$new" ]]; then
    echo "Usage: _agent-session-rename <old-name> <new-name>" >&2
    exit 1
fi

state_rename_session "$old" "$new"
